{
  "name": "nightowl",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:core": "vitest run src/core",
    "test:watch": "vitest",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug --cleanup",
    "e2e:test:ios:headed": "detox test --configuration ios.sim.debug --cleanup --headless false",
    "e2e:build:ios:release": "detox build --configuration ios.sim.release"
  },
  "dependencies": {
    "@stripe/stripe-react-native": "0.50.3",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "detox": "^20.47.0",
    "expect": "29.7.0",
    "jest": "^29.7.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "private": true
}
